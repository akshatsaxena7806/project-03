<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC 
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="SalaryDTO" table="ST_SALARY">

		<id name="id" type="java.lang.Long">
			<column name="ID" />
			<generator class="identity"/>
		</id>

		<!-- Unique Salary Code -->
		<property name="salaryCode" type="java.lang.String">
			<column name="SALARY_CODE" unique="true" not-null="true"/>
		</property>

		<property name="employeeName" type="java.lang.String">
			<column name="EMPLOYEE_NAME"/>
		</property>

		<property name="salaryAmount" type="java.lang.Long">
			<column name="SALARY_AMOUNT"/>
		</property>

		<property name="salaryStatus" type="java.lang.String">
			<column name="SALARY_STATUS"/>
		</property>

	</class>

</hibernate-mapping>